  (text "SUBOLI control unit - 2-layer carrier/motherboard schematic phase" (at 20.00 14.00 0) (effects (font (size 1.80 1.80)) (justify left)) (uuid "1ab63901-5b98-5c20-ae3e-e6a691ed3a8e"))
  (text "Panel-mounted parts are represented as wired panel headers. A1 is a purchased MA12070 module socket; A2 is an OPA1622 DIP-8 adapter/socket." (at 20.00 22.00 0) (effects (font (size 1.10 1.10)) (justify left)) (uuid "ab286b2a-de18-5f9a-9976-39cd7fd56f99"))
  (text "Tactile = stereo 2xBTL. Never common OUT0B/OUT1B. No output LC filter." (at 20.00 206.00 0) (effects (font (size 1.25 1.25)) (justify left)) (uuid "d1d156c4-d804-5a73-bb15-cbb7c18c8072"))
  (text "A1 EN/MUTE is intentionally left NC until the exact MA12070 module pad map and control behavior are supplied." (at 20.00 214.00 0) (effects (font (size 1.05 1.05)) (justify left)) (uuid "02320c98-ed8d-57fc-949a-4a8b4f5dd25a"))
  (text "Headphone output is AC-coupled: J4 sleeve connects to GND_SIG, not VGND." (at 20.00 222.00 0) (effects (font (size 1.05 1.05)) (justify left)) (uuid "4d532b13-b9c7-5310-a081-c7694ffabdde"))
  (text "NT1 is the only intended GND_SIG to GND_STAR connection. Keep Class-D return current out of the headphone/input area during layout." (at 20.00 230.00 0) (effects (font (size 1.05 1.05)) (justify left)) (uuid "04d6c432-c791-514b-93db-ec5af57314d1"))
  (text "C5/C7 decouple A2 +19V_HP to GND_STAR. C6/C8 decouple VGND to GND_SIG for bias stability." (at 20.00 238.00 0) (effects (font (size 1.05 1.05)) (justify left)) (uuid "ac05a169-f791-56a6-ab5b-943171edc474"))
